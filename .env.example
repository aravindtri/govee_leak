# Govee account (the same login you use in the Govee Home app)
GOVEE_EMAIL=you@example.com
GOVEE_PASSWORD=your-govee-password

# Home Assistant MQTT broker (Mosquitto add-on), used by govee2ha.py
MQTT_HOST=192.168.30.10
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DISCOVERY_PREFIX=homeassistant
